# ─────────────────────────────────────────────────────────────────────────────
# MTGS — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_DEBUG=true
APP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ── Database (Azure Database for PostgreSQL Flexible Server) ─────────────────
DATABASE_URL=postgresql+asyncpg://mtgs_user:password@localhost:5432/mtgs_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis (Azure Cache for Redis) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_NAME=mtgs-tool-embeddings

# ── Azure Key Vault (optional — for production secret management) ─────────────
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=mtgs@yourdomain.com

# ── Observability (OpenTelemetry) ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=mtgs-api

# ── Governance Defaults ───────────────────────────────────────────────────────
DEFAULT_SEMANTIC_SIMILARITY_THRESHOLD=0.80
DEFAULT_ROUTING_AMBIGUITY_THRESHOLD=0.30
DEFAULT_PROBE_QUERY_COUNT=50
DEFAULT_SIMULATION_TRIALS=3
CI_FAIL_ON_SEVERITY=HIGH     # CRITICAL | HIGH | MEDIUM | LOW
